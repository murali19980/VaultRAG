# Backend
OPENROUTER_API_KEY=your_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Database
# If PostgreSQL is not running, the application will automatically fall back to SQLite (vaultrag.db)
DATABASE_URL=postgresql://user:pass@localhost:5432/vaultrag

# LLM & Embedding Settings (Air-Gapped Operation)
USE_LOCAL_LLM=true
LOCAL_LLM_MODEL=qwen2.5:3b-instruct-q4_1
EMBEDDING_MODEL=all-minilm:l6-v2

# Chroma Vector DB Settings
CHROMA_COLLECTION=vaultrag
